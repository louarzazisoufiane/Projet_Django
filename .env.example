# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=your_password
DB_HOST=db
DB_PORT=5432

# ── PostgreSQL container (used by docker-compose) ───────────────────────────────
POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=your_password

# ── Initial admin account (created by the entrypoint) ───────────────────────────
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

# ── Image Docker du service web (publiée par la CI/CD) ──────────────────────────
# Par défaut: louarzazi/django-ecommerce:latest. Épinglez un tag précis si besoin.
WEB_IMAGE=louarzazi/django-ecommerce:latest
